# Copy to .env.local for local development.

# FastAPI backend (obsvagent/api/main.py), typically run via:
#   uvicorn obsvagent.api.main:app --reload --port 8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Only needed if the backend was started with OBSV_API_KEY set. See
# lib/api.ts for why this is a dev-only pattern, not production-safe.
# NEXT_PUBLIC_API_KEY=
